modules = ["nodejs-20", "nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/banco-web: web"

[[workflows.workflow]]
name = "artifacts/banco-web: web"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/banco-web run dev"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0", "javascript_object_storage:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 600000

[[ports]]
localPort = 3000
externalPort = 6800

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3003

[[ports]]
localPort = 8083
externalPort = 5173

[[ports]]
localPort = 8084
externalPort = 6000

[[ports]]
localPort = 21539
externalPort = 3001

[[ports]]
localPort = 22357
externalPort = 5000

[[ports]]
localPort = 23351
externalPort = 3000

[[ports]]
localPort = 23352
externalPort = 3002

[[ports]]
localPort = 23353
externalPort = 4200

[nix]
channel = "stable-25_05"
packages = ["psmisc"]

