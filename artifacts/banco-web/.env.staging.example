# BANCO Web — staging overrides (copy to .env.local on staging hosts)
# Production / default builds keep NEXT_PUBLIC_WEB_SEARCH_LIVE=false and MAP=false.
# Phase 2: enable LIVE (+ optional MAP) only on staging CDN against staging API.

# Staging: set VITE_WEB_URL on landing builds to the banco-web origin so root redirects to /directory
# Landing artifact (legacy nginx root) — optional; canonical hub is banco-web /directory

NEXT_PUBLIC_SITE_URL=https://staging-web.example.com
NEXT_PUBLIC_API_URL=https://staging-api.example.com

# Clerk required for save / contact /saved on web (W4+)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Staging: enable live browse against staging API
NEXT_PUBLIC_WEB_SEARCH_LIVE=true
NEXT_PUBLIC_WEB_SEARCH_MAP=true
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# After deploy:
# BANCO_WEB_URL=$NEXT_PUBLIC_SITE_URL BANCO_LISTING_SMOKE_ID=<uuid> node scripts/website-staging-smoke.mjs

# Leave empty to link same host /dealer-os/ and /admin-os/ (Replit unified)
NEXT_PUBLIC_MARKET_URL=
NEXT_PUBLIC_ADMIN_URL=
NEXT_PUBLIC_APP_ANDROID_URL=
NEXT_PUBLIC_APP_IOS_URL=

# Optional English mirror (hreflang en) when a separate EN site exists
NEXT_PUBLIC_SITE_URL_EN=

NEXT_PUBLIC_SEARCH_ENABLED=true
NEXT_PUBLIC_SEARCH_ANALYTICS_MODE=debug
